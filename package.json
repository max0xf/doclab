{
  "name": "doclab",
  "version": "0.1.0",
  "private": true,
  "proxy": "http://localhost:8000",
  "engines": {
    "node": "25.1.0"
  },
  "dependencies": {
    "@acronis-platform/ui-syntax": "1.0.1",
    "@expressive-code/core": "^0.41.7",
    "@expressive-code/plugin-line-numbers": "^0.41.7",
    "@monaco-editor/react": "^4.7.0",
    "@tanstack/react-virtual": "3.0.1",
    "@tiptap/extension-code-block-lowlight": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "@types/js-yaml": "^4.0.9",
    "hast-util-to-jsx-runtime": "^2.3.6",
    "lowlight": "^3.3.0",
    "lucide-react": "0.294.0",
    "memoize-one": "6.0.0",
    "prism-react-renderer": "^2.4.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "react-markdown": "10.1.0",
    "rehype-expressive-code": "^0.41.7",
    "rehype-highlight": "^7.0.2",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "4.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "start:local": "./scripts/run-local.sh",
    "start:backend": "cd src/backend && source venv/bin/activate && python manage.py runserver 0.0.0.0:8000",
    "build": "react-scripts build",
    "test": "cross-env TZ=UTC NO_WARN=true LANG=en_US.UTF-8 react-app-rewired test --watchAll=false --passWithNoTests",
    "test:update-snapshots": "npm run test -- --watchAll=false -u --passWithNoTests",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "test:coverage": "npm run test -- --watchAll=false --coverage --passWithNoTests",
    "test:ci": "cross-env TZ=UTC NO_WARN=true LANG=en_US.UTF-8 jest --coverage --passWithNoTests --ci --bail",
    "type-check": "tsc --noEmit",
    "eject": "react-scripts eject",
    "postinstall": "patch-package",
    "prepare": "husky",
    "lint": "eslint src/frontend --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint src/frontend --ext .ts,.tsx,.js,.jsx --fix",
    "lint:specs": "markdownlint-cli2 \"openspec/**/*.md\" \"docs/**/*.md\"",
    "lint:specs:fix": "markdownlint-cli2 --fix \"openspec/**/*.md\" \"docs/**/*.md\"",
    "format": "prettier --write \"src/frontend/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "format:check": "prettier --check \"src/frontend/**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "knip": "knip --no-config-hints",
    "knip:production": "knip --production"
  },
  "lint-staged": {
    "src/frontend/**/*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/frontend/**/*.{json,css,md}": [
      "prettier --write"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "overrides": {
    "glob": "11.1.0",
    "@zkochan/rimraf": {
      "rimraf": "3.0.2"
    },
    "rimraf": "6.1.3",
    "test-exclude": {
      "glob": "7.2.3",
      "minimatch": "3.1.5"
    },
    "node-forge": "1.3.2",
    "nth-check": "2.1.1",
    "js-yaml": "4.1.1",
    "mdast-util-to-hast": "13.2.1",
    "prismjs": "1.30.0",
    "webpack-dev-server": "5.2.1",
    "bfj": "9.1.3",
    "resolve-url-loader": {
      "postcss": "$postcss"
    },
    "serialize-javascript": ">=7.0.3",
    "@tootallnate/once": "3.0.1"
  },
  "devDependencies": {
    "@playwright/test": "1.57.0",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "5.16.5",
    "@testing-library/react": "13.4.0",
    "@testing-library/user-event": "13.5.0",
    "@types/hast": "^3.0.4",
    "@types/jest": "27.5.2",
    "@types/node": "24.5.2",
    "@types/react": "18.3.26",
    "@types/react-dom": "18.3.7",
    "autoprefixer": "10.4.21",
    "cross-env": "10.1.0",
    "eslint-config-prettier": "10.1.5",
    "eslint-plugin-prettier": "5.4.0",
    "eslint-plugin-testing-library": "7.15.4",
    "husky": "9.0.11",
    "jest-environment-jsdom": "30.2.0",
    "knip": "2.43.0",
    "lint-staged": "13.2.3",
    "markdownlint-cli2": "0.21.0",
    "patch-package": "8.0.1",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "react-app-rewired": "2.2.1",
    "react-scripts": "5.0.1",
    "tailwindcss": "3.4.18",
    "ts-jest": "29.4.6",
    "typescript": "4.9.5"
  }
}
