# Backend API URL (handles authentication and data proxy)
REACT_APP_AUTH_API_URL=http://localhost:8000

# App version info (auto-populated by build scripts from VERSION file and git)
REACT_APP_VERSION=1.0
REACT_APP_BUILD_REF=dev

# =============================================================================
# Django Backend Settings (for docker-compose)
# =============================================================================

# Django - REQUIRED: Generate a unique secret key for your deployment
# Use: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
DJANGO_SECRET_KEY=
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# OIDC (SSO) - REQUIRED for SSO
OIDC_CLIENT_ID=
OIDC_CLIENT_SECRET=

# Redirect URLs
LOGIN_REDIRECT_URL=http://localhost:3000/
LOGOUT_REDIRECT_URL=http://localhost:3000/

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# =============================================================================
# Database
# =============================================================================
# DB_ENGINE=sqlite        ← default (local dev / CI — no extra config needed)
# DB_ENGINE=postgresql    ← set this for staging / production

# Required when DB_ENGINE=postgresql:
# DB_NAME=cyber_wiki
# DB_USER=postgres
# DB_PASSWORD=
# DB_HOST=localhost
# DB_PORT=5432

# =============================================================================
# Git token encryption
# =============================================================================
# Fernet key for encrypting per-user git tokens at rest.
# Auto-derived from DJANGO_SECRET_KEY when not set (not recommended for production).
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
GIT_TOKEN_ENCRYPTION_KEY=

# Git provider (GitHub, GitLab, Bitbucket)
GIT_PROVIDER=github
GIT_API_URL=https://api.github.com
GIT_API_TOKEN=

# JIRA integration
JIRA_URL=
JIRA_API_TOKEN=

# Frontend
FRONTEND_URL=http://localhost:3000

# SSL/TLS - For corporate CA certificates
# REQUESTS_CA_BUNDLE=/path/to/ca-bundle.crt
